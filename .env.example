# Copy this file to `.env` and fill in your values. `.env` is gitignored.
#
# OpenReview credentials for authenticated bulk collection. Anonymous access is
# blocked by OpenReview's anti-bot challenge (ChallengeRequiredError); a
# logged-in client clears it. Free account: https://openreview.net
#
# esai_collection/openreview_source.py reads OPENREVIEW_USERNAME and
# OPENREVIEW_PASSWORD from the environment. Load this file before running, e.g.:
#   set -a && source .env && set +a && esai-collect run ...

OPENREVIEW_USERNAME='you@example.com'
OPENREVIEW_PASSWORD='your-password-here'
